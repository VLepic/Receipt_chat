APP_NAME=SP2 Assistant
ENVIRONMENT=local
SECRET_KEY=change-me
DATABASE_URL=postgresql+asyncpg://sp2:sp2@postgres:5432/sp2
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

COOKIE_NAME=sp2_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

OLLAMA_BASE_URL=https://ollama.example.com
OLLAMA_SERVER_1_NAME=Server 1
OLLAMA_MODEL=phi4
EXTRACTION_MODEL=
OLLAMA_USERNAME=
OLLAMA_PASSWORD=
OLLAMA_AUTH_SCHEME=digest
OLLAMA_SERVER_2_NAME=Server 2
OLLAMA_SERVER_2_BASE_URL=
OLLAMA_SERVER_2_USERNAME=
OLLAMA_SERVER_2_PASSWORD=
OLLAMA_SERVER_2_AUTH_SCHEME=digest
OLLAMA_TIMEOUT_SECONDS=60
RAG_EMBEDDING_MODEL=qwen3-embedding:latest
RAG_RERANKER_MODEL=
RAG_RERANKER_CANDIDATE_LIMIT=10
RAG_RERANKER_TIMEOUT_SECONDS=180

DOCUMENT_STORAGE_DIR=/app/storage/documents
DOCUMENT_MAX_UPLOAD_BYTES=10485760
OCR_LANGUAGE=ces+eng
OCR_ENGINE=easyocr
EASYOCR_LANGUAGES=cs,en
EASYOCR_MAX_IMAGE_SIDE=1800
OCR_WORKER_POLL_SECONDS=5

SPEECH_DIALOG_HOST=0.0.0.0
SPEECH_DIALOG_PORT=8888
SPEECH_STATIC_PATH=./static
SPEECH_SYSTEM_PROMPT=Odpovidej strucne v cestine.
BACKEND_API_BASE_URL=http://backend:8000/api
VOICE_ATTACH_TIMEOUT_SECONDS=30

VITE_SPEECHCLOUD_SCRIPT_URL=
VITE_SPEECHCLOUD_MODEL_URI=
VITE_SPEECH_DIALOG_LOCAL_DM=
