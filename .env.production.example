APP_NAME=ReceiptChat
ENVIRONMENT=production

# Generate fresh secrets before deployment.
SECRET_KEY=replace-with-a-long-random-secret
POSTGRES_DB=sp2
POSTGRES_USER=sp2
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Persistent data directory on the Docker host.
SP2_DATA_DIR=/opt/stacks/sp2/data

# Host ports consumed by your external nginx reverse proxy.
FRONTEND_PORT=5173
BACKEND_PORT=8000
SPEECH_DIALOG_PORT=8888

# Public domains handled by your external nginx reverse proxy.
FRONTEND_PUBLIC_URL=https://receiptchat.vaclavlepic.com
BACKEND_PUBLIC_URL=https://apireceiptchat.vaclavlepic.com
SPEECH_DIALOG_PUBLIC_WS=wss://receiptchat.vaclavlepic.com/ws

# Backend security. CORS must contain the frontend origin, not the API origin.
CORS_ORIGINS=["https://receiptchat.vaclavlepic.com"]
COOKIE_NAME=sp2_session
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Frontend build-time configuration. Rebuild frontend after changing these.
VITE_API_BASE_URL=https://apireceiptchat.vaclavlepic.com/api
VITE_SPEECHCLOUD_SCRIPT_URL=https://speechcloud.kky.zcu.cz:9444/speechcloud-3.0.js
VITE_SPEECHCLOUD_MODEL_URI=https://speechcloud.kky.zcu.cz:9443/v1/speechcloud/edu-hds-all
VITE_SPEECH_DIALOG_LOCAL_DM=/ws

# Ollama server 1.
OLLAMA_BASE_URL=http://192.168.20.22:11434
OLLAMA_SERVER_1_NAME=Server 1
OLLAMA_MODEL=gemma3:4b
EXTRACTION_MODEL=
OLLAMA_USERNAME=
OLLAMA_PASSWORD=
OLLAMA_AUTH_SCHEME=digest
OLLAMA_TIMEOUT_SECONDS=60

# Optional Ollama server 2.
OLLAMA_SERVER_2_NAME=Server 2
OLLAMA_SERVER_2_BASE_URL=
OLLAMA_SERVER_2_USERNAME=
OLLAMA_SERVER_2_PASSWORD=
OLLAMA_SERVER_2_AUTH_SCHEME=digest

# RAG and reranker.
RAG_EMBEDDING_MODEL=qwen3-embedding:8b
RAG_RERANKER_MODEL=dengcao/Qwen3-Reranker-8B:Q5_K_M
RAG_RERANKER_CANDIDATE_LIMIT=10
RAG_RERANKER_TIMEOUT_SECONDS=180
RAG_SEARCH_LIMIT=5

# Documents and OCR.
DOCUMENT_MAX_UPLOAD_BYTES=10485760
OCR_LANGUAGE=ces+eng
OCR_ENGINE=ollama
OLLAMA_OCR_MODEL=glm-ocr:latest
OLLAMA_OCR_PROMPT=Text Recognition:
OLLAMA_OCR_TIMEOUT_SECONDS=180
EASYOCR_LANGUAGES=cs,en
EASYOCR_MAX_IMAGE_SIDE=1800
OCR_WORKER_POLL_SECONDS=5

# Speech dialog manager.
SPEECH_STATIC_PATH=./static
SPEECH_SYSTEM_PROMPT=Odpovidej strucne v cestine.
VOICE_ATTACH_TIMEOUT_SECONDS=30
